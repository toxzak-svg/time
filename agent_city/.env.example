# OpenClaw / Agent City — copy this to ~/.openclaw/.env and fill in values.
# OpenClaw loads ~/.openclaw/.env automatically (see docs.openclaw.ai/help/environment).
# Do not commit .env; keep keys out of openclaw.json.

# Required for model API calls (OpenAI/Codex, etc.). Fixes "Open AI not configured" / API errors.
OPENAI_API_KEY=

# Agent City paths (optional if already in openclaw.json env.vars)
AGENT_CITY_REPO=
MOLTBOOK_REPORT_PATH=

# Optional: Moltbook app key (moltdev_...) for publishing
# MOLTBOOK_APP_KEY=
